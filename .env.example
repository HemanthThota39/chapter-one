# Copy this to `.env` and fill in real values. `.env` is gitignored; never commit secrets.

# Azure AI Foundry (Azure OpenAI)
AZURE_OPENAI_ENDPOINT=https://testingclaudecode.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-chat

# Database (local Docker Compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chapter_one

# Cache
REDIS_URL=redis://localhost:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Observability
LOG_DIR=./logs
LOG_RAW_RESPONSES=true
LOG_IDEA_TEXT=false

# Research engine
RESEARCH_CONCURRENCY=4
